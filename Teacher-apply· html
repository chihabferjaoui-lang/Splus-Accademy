<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teacher Application | S+ English Academy</title>
  <meta name="description" content="Apply to join S+ English Academy as an English teacher through our guided chat-style application form." />

  <style>
    :root {
      --bg: #f6f6fb;
      --card: rgba(255,255,255,0.94);
      --text: #0f1230;
      --muted: #697086;
      --line: #d8dff0;
      --primary: #5e2ca5;
      --primary-2: #3d66e6;
      --accent: #35d0c8;
      --shadow: 0 18px 50px rgba(22, 26, 68, 0.12);
      --radius: 24px;
      --serif: Georgia, "Times New Roman", serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --max: 1100px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: var(--sans);
      color: var(--text);
      background: linear-gradient(135deg, #f7f8fd 0%, #f3f5ff 30%, #f9fbff 100%);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button, input, textarea, select { font: inherit; }

    .container {
      width: min(var(--max), calc(100% - 32px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(248,249,255,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(61,102,230,0.08);
    }

    .nav {
      min-height: 82px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand img {
      width: 46px;
      height: 46px;
      object-fit: contain;
      border-radius: 12px;
    }

    .brand span {
      font-family: var(--serif);
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--primary);
    }

    .nav-links {
      display: flex;
      gap: 22px;
      align-items: center;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: var(--muted);
      font-size: 0.96rem;
    }

    .nav-links a.active,
    .nav-links a:hover {
      color: var(--primary);
      font-weight: 700;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 22px;
      border-radius: 14px;
      border: 1px solid transparent;
      font-weight: 700;
      cursor: pointer;
      transition: transform .22s ease, box-shadow .22s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(61,102,230,0.16);
    }

    .btn-primary {
      color: #fff;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
    }

    .btn-outline {
      color: var(--primary);
      border-color: var(--primary);
      background: rgba(255,255,255,0.74);
    }

    .hero {
      padding: 58px 0 38px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      align-items: center;
      gap: 42px;
    }

    .eyebrow {
      color: var(--primary-2);
      text-transform: uppercase;
      letter-spacing: .12em;
      font-size: .82rem;
      font-weight: 800;
      margin-bottom: 12px;
    }

    h1, h2, h3 {
      font-family: var(--serif);
      color: #0b102c;
      margin: 0;
      line-height: 1.05;
    }

    h1 {
      font-size: clamp(2.7rem, 6vw, 4.8rem);
      margin-bottom: 18px;
    }

    .hero p.lead {
      color: #5d647c;
      font-size: 1.14rem;
      margin: 0 0 14px;
      max-width: 720px;
    }

    .hero p.sub {
      color: #7a8095;
      margin: 0 0 28px;
      max-width: 700px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .hero-media,
    .assistant-shell,
    .info-card,
    .success-card {
      border: 1px solid var(--line);
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero-media {
      padding: 12px;
    }

    .hero-media img {
      width: 100%;
      min-height: 390px;
      object-fit: cover;
      border-radius: 18px;
    }

    section {
      padding: 74px 0;
    }

    .section-head {
      text-align: center;
      max-width: 860px;
      margin: 0 auto 34px;
    }

    .section-head h2 {
      font-size: clamp(2.2rem, 4.4vw, 4rem);
      margin-bottom: 12px;
    }

    .section-head p {
      margin: 0;
      color: var(--muted);
      font-size: 1.08rem;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 22px;
    }

    .info-card {
      padding: 24px;
    }

    .info-card h3 {
      font-size: 1.45rem;
      margin-bottom: 10px;
    }

    .info-card p {
      margin: 0;
      color: var(--muted);
    }

    .assistant-shell {
      max-width: 980px;
      margin: 0 auto;
      overflow: hidden;
    }

    .assistant-top {
      padding: 22px 24px;
      color: #fff;
      background: linear-gradient(135deg, var(--primary), var(--primary-2), var(--accent));
    }

    .assistant-top h3 {
      font-family: var(--sans);
      font-size: 1.35rem;
      margin: 0 0 4px;
      color: #fff;
    }

    .assistant-top p {
      margin: 0;
      opacity: .94;
    }

    .assistant-body {
      padding: 22px;
      background: linear-gradient(180deg, rgba(244,246,255,0.96), rgba(255,255,255,0.96));
      min-height: 560px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .messages {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .bubble {
      max-width: 780px;
      padding: 16px 18px;
      border-radius: 18px;
      font-size: 1rem;
      line-height: 1.6;
      white-space: pre-line;
    }

    .bubble.bot {
      align-self: flex-start;
      background: #eef1fb;
      color: #28304f;
      border-top-left-radius: 6px;
    }

    .bubble.user {
      align-self: flex-end;
      background: linear-gradient(135deg, var(--accent), var(--primary-2));
      color: #fff;
      border-top-right-radius: 6px;
    }

    .choice-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .choice-btn {
      width: 100%;
      text-align: left;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      padding: 14px 16px;
      border-radius: 16px;
      cursor: pointer;
      font-weight: 700;
      transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease;
    }

    .choice-btn:hover {
      border-color: var(--primary-2);
      transform: translateY(-1px);
      box-shadow: 0 10px 20px rgba(61,102,230,0.1);
    }

    .choice-btn small {
      display: block;
      color: var(--muted);
      font-weight: 500;
      margin-top: 4px;
    }

    .inline-input,
    .inline-textarea {
      width: 100%;
      border: 1px solid var(--line);
      background: #fff;
      padding: 14px 16px;
      border-radius: 14px;
      margin-top: 10px;
      color: var(--text);
    }

    .inline-textarea {
      min-height: 120px;
      resize: vertical;
    }

    .label {
      font-size: .9rem;
      color: var(--muted);
      font-weight: 700;
      margin-top: 6px;
    }

    .summary {
      background: rgba(238,241,251,0.86);
      padding: 16px;
      border-radius: 16px;
      border: 1px solid var(--line);
      color: #2b3558;
    }

    .summary strong {
      color: var(--primary);
    }

    .action-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .success-card {
      margin-top: 14px;
      padding: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(245,248,255,.98));
    }

    .success-card h4 {
      margin: 0 0 10px;
      font-size: 1.35rem;
      color: var(--primary);
    }

    .success-card p {
      margin: 0 0 10px;
      color: var(--muted);
    }

    .footer {
      padding: 54px 0 28px;
      border-top: 1px solid rgba(61,102,230,0.08);
      background: rgba(255,255,255,0.55);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.25fr 1fr 1fr;
      gap: 28px;
      margin-bottom: 22px;
    }

    .footer h4 {
      margin: 0 0 12px;
      font-size: 1.2rem;
    }

    .footer p, .footer li, .footer a {
      color: var(--muted);
    }

    .footer ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }

    .bottom {
      border-top: 1px solid rgba(61,102,230,0.08);
      padding-top: 20px;
      display: flex;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
      color: var(--muted);
    }

    .hidden {
      display: none !important;
    }

    @media (max-width: 980px) {
      .hero-grid,
      .info-grid,
      .footer-grid,
      .choice-grid {
        grid-template-columns: 1fr 1fr;
      }

      .nav-links {
        display: none;
      }
    }

    @media (max-width: 720px) {
      .hero-grid,
      .info-grid,
      .footer-grid,
      .choice-grid {
        grid-template-columns: 1fr;
      }

      .hero-media img {
        min-height: 280px;
      }

      .hero-actions,
      .action-row,
      .bottom {
        flex-direction: column;
        align-items: stretch;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>

