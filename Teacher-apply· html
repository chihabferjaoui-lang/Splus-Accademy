  <script>
    const state = {
      experience: null,
      certification: null,
      specialization: null,
      availability: null,
      name: null,
      email: null,
      phone: null,
      reference: null
    };

    const certificationOptions = [
      'TEFL', 'TESOL', 'CELTA', 'DELTA', 'Trinity CertTESOL', 'Other certification'
    ];

    const specializationOptions = [
      'Business English', 'Exam Preparation', 'Conversational English', 'IELTS / TOEFL', 'Speaking Skills', 'Young Learners'
    ];

    const availabilityOptions = [
      'Full-time', 'Part-time', 'Weekends only', 'Flexible hours', 'Evenings', 'Mornings'
    ];

    const messages = document.getElementById('messages');
    const interactiveArea = document.getElementById('interactiveArea');
    const resultArea = document.getElementById('resultArea');

    function bot(text) {
      const div = document.createElement('div');
      div.className = 'bubble bot';
      div.textContent = text;
      messages.appendChild(div);
      div.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }

    function user(text) {
      const div = document.createElement('div');
      div.className = 'bubble user';
      div.textContent = text;
      messages.appendChild(div);
      div.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }

    function setInteractive(html) {
      interactiveArea.innerHTML = html;
    }

    function optionButtons(items) {
      return `<div class="option-grid">${items.map((item, idx) => `<button class="choice-btn" data-choice="${idx}">${item}</button>`).join('')}</div>`;
    }

    function actionButtons() {
      return `<div class="action-row">
        <button class="btn btn-primary" id="confirmBtn">Confirm</button>
        <button class="btn btn-outline" id="restartBtn">Start Over</button>
      </div>`;
    }

    function generateReference(prefix = 'TCH') {
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      let a = '', b = '';
      for (let i = 0; i < 8; i++) a += chars[Math.floor(Math.random() * chars.length)];
      for (let i = 0; i < 5; i++) b += chars[Math.floor(Math.random() * chars.length)];
      return `${prefix}-${a}-${b}`;
    }

    function escapeHTML(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function createTeacherPDF() {
      const dateText = new Date().toLocaleString();
      const html = `<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Teacher Application Confirmation - ${escapeHTML(state.reference)}</title>
<style>
body{font-family:Arial,sans-serif;background:#f5f6fb;margin:0;padding:30px;color:#1f2748}
.card{max-width:860px;margin:0 auto;background:#fff;border:1px solid #d9deea;border-radius:20px;padding:34px;box-shadow:0 12px 30px rgba(0,0,0,.06)}
.head{text-align:center;border-bottom:1px solid #e2e7f2;padding-bottom:18px;margin-bottom:26px}
.head h1{margin:0;color:#5e2ca5;font-size:34px}
.head p{margin:8px 0 0;color:#66708b}
.ref{padding:18px;border-radius:16px;background:#f0effb;text-align:center;margin-bottom:22px;border:1px solid #ddd7ff}
.ref small{display:block;color:#6d77a0;letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px}
.ref strong{font-size:28px;color:#3d66e6}
.section{border:1px solid #d9deea;border-radius:16px;padding:20px;margin-bottom:20px;background:#fbfcff}
.section h2{font-size:18px;margin:0 0 12px;color:#5e2ca5}
.row{margin:8px 0}
.note{background:#eef8ff;border:1px solid #cfe6ff;padding:18px;border-radius:16px;color:#2b3558}
.footer{margin-top:22px;color:#7a8299;font-size:14px}
.watermark{position:fixed;top:44%;left:50%;transform:translate(-50%,-50%) rotate(-24deg);font-size:64px;color:rgba(53,208,200,.12);font-weight:800;pointer-events:none;white-space:nowrap}
</style>
</head>
<body>
<div class="watermark">WAITING REVIEW • S+ ENGLISH ACADEMY</div>
<div class="card">
  <div class="head">
    <h1>Application Confirmation</h1>
    <p>Teacher Position • S+ English Academy</p>
  </div>
  <div class="ref">
    <small>Reference Number</small>
    <strong>${escapeHTML(state.reference)}</strong>
  </div>
  <div class="section">
    <h2>Your Application Details</h2>
    <div class="row"><strong>Name:</strong> ${escapeHTML(state.name)}</div>
    <div class="row"><strong>Email:</strong> ${escapeHTML(state.email)}</div>
    <div class="row"><strong>Phone:</strong> ${escapeHTML(state.phone)}</div>
    <div class="row"><strong>Years of Experience:</strong> ${escapeHTML(state.experience)}</div>
    <div class="row"><strong>Certification:</strong> ${escapeHTML(state.certification)}</div>
    <div class="row"><strong>Specialization:</strong> ${escapeHTML(state.specialization)}</div>
    <div class="row"><strong>Availability:</strong> ${escapeHTML(state.availability)}</div>
    <div class="row"><strong>Status:</strong> Waiting review</div>
  </div>
  <div class="note">
    <strong>Next step:</strong> Please send this PDF with your reference number, along with your CV, to <strong>contact.englishcourse94@gmail.com</strong>. Our team will review your application and contact you within 24 hours.
  </div>
  <div class="footer">Document generated on ${escapeHTML(dateText)}</div>
</div>
</body>
</html>`;

      const win = window.open('', '_blank');
      win.document.open();
      win.document.write(html);
      win.document.close();
      return win;
    }

    function renderPDFActions() {
      resultArea.innerHTML = `
        <div class="result-box">
          <h4>Application PDF Ready</h4>
          <p>Your teacher application confirmation has been generated with reference number <strong>${state.reference}</strong>.</p>
          <p>Please download or print the PDF and send it, together with your CV, to <strong>contact.englishcourse94@gmail.com</strong>.</p>
          <div class="result-actions">
            <button class="btn btn-primary" id="viewPdfBtn">View / Print PDF</button>
            <a class="btn btn-outline" href="mailto:contact.englishcourse94@gmail.com?subject=Teacher%20Application%20${encodeURIComponent(state.reference)}">Email Application</a>
          </div>
          <div class="note">The PDF includes a unique reference number and a waiting review watermark for tracking.</div>
        </div>`;
      document.getElementById('viewPdfBtn').addEventListener('click', () => {
        const pdfWindow = createTeacherPDF();
        setTimeout(() => pdfWindow.print(), 500);
      });
      resultArea.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function startFlow() {
      messages.innerHTML = '';
      interactiveArea.innerHTML = '';
      resultArea.innerHTML = '';
      Object.assign(state, { experience: null, certification: null, specialization: null, availability: null, name: null, email: null, phone: null, reference: null });

      bot('Welcome to S+ Academy. Let’s begin your teacher application by understanding your background. How many years have you been teaching English?');
      setInteractive(`
        <div class="label">Years of teaching experience</div>
        <input class="inline-input" id="expInput" placeholder="Example: 2 years" />
        <div style="height:14px"></div>
        <button class="btn btn-primary" id="expNext">Continue</button>
      `);
      document.getElementById('expNext').addEventListener('click', () => {
        const value = document.getElementById('expInput').value.trim();
        if (!value) return alert('Please enter your teaching experience.');
        state.experience = value;
        user(value);
        askCertification();
      });
    }

    function askCertification() {
      bot('Great. Which English teaching certification do you hold?');
      setInteractive(optionButtons(certificationOptions));
      interactiveArea.querySelectorAll('[data-choice]').forEach(btn => {
        btn.addEventListener('click', () => {
          state.certification = certificationOptions[Number(btn.dataset.choice)];
          user(state.certification);
          askSpecialization();
        });
      });
    }

    function askSpecialization() {
      bot('Excellent. What subjects or areas do you specialize in?');
      setInteractive(optionButtons(specializationOptions));
      interactiveArea.querySelectorAll('[data-choice]').forEach(btn => {
        btn.addEventListener('click', () => {
          state.specialization = specializationOptions[Number(btn.dataset.choice)];
          user(state.specialization);
          askAvailability();
        });
      });
    }

    function askAvailability() {
      bot('What is your availability like?');
      setInteractive(optionButtons(availabilityOptions));
      interactiveArea.querySelectorAll('[data-choice]').forEach(btn => {
        btn.addEventListener('click', () => {
          state.availability = availabilityOptions[Number(btn.dataset.choice)];
          user(state.availability);
          askName();
        });
      });
    }

    function askName() {
      bot('Now I need your contact details. Please enter your full name.');
      setInteractive(`
        <div class="label">Full name</div>
        <input class="inline-input" id="nameInput" placeholder="Your full name" />
        <div style="height:14px"></div>
        <button class="btn btn-primary" id="nameNext">Continue</button>
      `);
      document.getElementById('nameNext').addEventListener('click', () => {
        const value = document.getElementById('nameInput').value.trim();
        if (!value) return alert('Please enter your full name.');
        state.name = value;
        user(value);
        askEmail();
      });
    }

    function askEmail() {
      bot('Please enter your email address.');
      setInteractive(`
        <div class="label">Email address</div>
        <input class="inline-input" id="emailInput" type="email" placeholder="name@example.com" />
        <div style="height:14px"></div>
        <button class="btn btn-primary" id="emailNext">Continue</button>
      `);
      document.getElementById('emailNext').addEventListener('click', () => {
        const value = document.getElementById('emailInput').value.trim();
        if (!value || !value.includes('@')) return alert('Please enter a valid email address.');
        state.email = value;
        user(value);
        askPhone();
      });
    }

    function askPhone() {
      bot('Please enter your phone or WhatsApp number.');
      setInteractive(`
        <div class="label">Phone / WhatsApp</div>
        <input class="inline-input" id="phoneInput" placeholder="+212 ..." />
        <div style="height:14px"></div>
        <button class="btn btn-primary" id="phoneNext">Continue</button>
      `);
      document.getElementById('phoneNext').addEventListener('click', () => {
        const value = document.getElementById('phoneInput').value.trim();
        if (!value) return alert('Please enter your phone number.');
        state.phone = value;
        user(value);
        confirmSummary();
      });
    }

    function confirmSummary() {
      bot('Please review your application details. If everything is correct, confirm to generate your PDF confirmation.');
      setInteractive(`
        <div class="summary">
          <div><strong>Experience:</strong> ${state.experience}</div>
          <div><strong>Certification:</strong> ${state.certification}</div>
          <div><strong>Specialization:</strong> ${state.specialization}</div>
          <div><strong>Availability:</strong> ${state.availability}</div>
          <div><strong>Name:</strong> ${state.name}</div>
          <div><strong>Email:</strong> ${state.email}</div>
          <div><strong>Phone:</strong> ${state.phone}</div>
        </div>
        <div style="height:14px"></div>
        ${actionButtons()}
      `);
      document.getElementById('confirmBtn').addEventListener('click', () => {
        state.reference = generateReference('TCH');
        user('Confirm');
        bot(`Your application is ready. Reference number: ${state.reference}. Please use the PDF below and send it with your CV to contact.englishcourse94@gmail.com.`);
        setInteractive(`<div class="summary"><strong>Status:</strong> Waiting review<br><strong>Reference:</strong> ${state.reference}</div><div style="height:14px"></div><button class="btn btn-outline" id="restartFlowBtn">Start New Application</button>`);
        document.getElementById('restartFlowBtn').addEventListener('click', startFlow);
        renderPDFActions();
      });
      document.getElementById('restartBtn').addEventListener('click', () => {
        user('Start Over');
        startFlow();
      });
    }

    startFlow();
  </script>
</body>
</html>
