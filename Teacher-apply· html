<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>S+ English Academy | Teacher Application Assistant</title>
  <meta name="description" content="Apply to join S+ English Academy through an interactive teacher application assistant and generate a PDF confirmation with a reference number." />
  <style>
    :root {
      --bg: #f6f6fb;
      --card: rgba(255,255,255,0.92);
      --text: #11152f;
      --muted: #6e748a;
      --line: #d8dff0;
      --primary: #5e2ca5;
      --primary-2: #3d66e6;
      --accent: #35d0c8;
      --shadow: 0 18px 50px rgba(22, 26, 68, 0.12);
      --radius: 24px;
      --serif: Georgia, "Times New Roman", serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--sans);
      color: var(--text);
      background: linear-gradient(135deg, #f7f8fd 0%, #f2f5ff 35%, #f9fbff 100%);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button, input, textarea { font: inherit; }

    .container { width: min(var(--max), calc(100% - 32px)); margin: 0 auto; }

    .topbar {
      position: sticky; top: 0; z-index: 20;
      background: rgba(248,249,255,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(61,102,230,0.08);
    }

    .nav {
      min-height: 82px;
      display: flex; align-items: center; justify-content: space-between; gap: 20px;
    }

    .brand { display: flex; align-items: center; gap: 12px; }
    .brand img { width: 46px; height: 46px; object-fit: contain; border-radius: 12px; }
    .brand span { font-family: var(--serif); font-size: 1.45rem; font-weight: 700; color: var(--primary); }

    .nav-links { display: flex; gap: 22px; align-items: center; flex-wrap: wrap; }
    .nav-links a { color: var(--muted); font-size: .96rem; }
    .nav-links a.active, .nav-links a:hover { color: var(--primary); font-weight: 700; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      padding: 14px 22px; border-radius: 14px; border: 1px solid transparent;
      font-weight: 700; cursor: pointer;
      transition: transform .22s ease, box-shadow .22s ease;
    }

    .btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(61,102,230,0.16); }
    .btn-primary { color: #fff; background: linear-gradient(135deg, var(--primary), var(--primary-2)); }
    .btn-outline { color: var(--primary); border-color: var(--primary); background: rgba(255,255,255,0.8); }

    .hero {
      padding: 60px 0 42px;
      position: relative; overflow: hidden;
    }

    .hero::before,
    .hero::after {
      content: ""; position: absolute; border-radius: 50%; filter: blur(70px); opacity: .18; pointer-events: none;
    }

    .hero::before { width: 420px; height: 420px; background: var(--primary); top: -100px; left: -120px; }
    .hero::after { width: 360px; height: 360px; background: var(--accent); right: -70px; bottom: -80px; }

    .hero-grid {
      display: grid; grid-template-columns: 1.08fr .92fr; gap: 48px; align-items: center;
    }

    .eyebrow {
      color: var(--primary-2); text-transform: uppercase; letter-spacing: .12em;
      font-size: .82rem; font-weight: 800; margin-bottom: 12px;
    }

    h1, h2, h3 { font-family: var(--serif); color: #0b102c; margin: 0; line-height: 1.05; }
    h1 { font-size: clamp(2.8rem, 6vw, 5rem); margin-bottom: 18px; }
    .hero p.lead { color: #5d647c; font-size: 1.15rem; margin: 0 0 14px; max-width: 760px; }
    .hero p.sub { color: #7a8095; margin: 0 0 28px; max-width: 720px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }

    .hero-media,
    .card,
    .assistant-shell,
    .result-box,
    .teacher-panel {
      border: 1px solid var(--line);
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero-media { padding: 12px; }
    .hero-media img { border-radius: 18px; width: 100%; object-fit: cover; min-height: 420px; }

    section { padding: 78px 0; }
    .section-head { text-align: center; max-width: 860px; margin: 0 auto 34px; }
    .section-head h2 { font-size: clamp(2.2rem, 4.4vw, 4rem); margin-bottom: 12px; }
    .section-head p { margin: 0; color: var(--muted); font-size: 1.12rem; }

    .teacher-grid {
      display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 22px;
    }

    .teacher-panel { padding: 24px; }
    .teacher-panel h3 { font-size: 1.55rem; margin-bottom: 10px; }
    .teacher-panel ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; color: var(--muted); }

    .steps {
      display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 20px; margin-top: 28px;
    }

    .step { text-align: center; padding: 12px 10px; }
    .num {
      width: 54px; height: 54px; margin: 0 auto 14px; display: grid; place-items: center;
      border-radius: 999px; color: #fff; font-weight: 800;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
    }

    .step strong { display: block; font-size: 1.1rem; margin-bottom: 6px; }
    .step span { color: var(--muted); font-size: .95rem; }

    .assistant-shell {
      max-width: 980px; margin: 0 auto; overflow: hidden;
    }

    .assistant-top {
      padding: 22px 24px; color: #fff;
      background: linear-gradient(135deg, var(--primary), var(--primary-2), var(--accent));
    }

    .assistant-top h3 {
      font-family: var(--sans); font-size: 1.35rem; margin: 0 0 4px; color: #fff;
    }

    .assistant-top p { margin: 0; opacity: .92; }

    .assistant-body {
      padding: 22px; min-height: 560px;
      background: linear-gradient(180deg, rgba(244,246,255,0.96), rgba(255,255,255,0.96));
      display: flex; flex-direction: column; gap: 16px;
    }

    .messages { display: flex; flex-direction: column; gap: 14px; }

    .bubble {
      max-width: 760px; padding: 16px 18px; border-radius: 18px; font-size: 1rem; line-height: 1.6; white-space: pre-line;
    }

    .bubble.bot { align-self: flex-start; background: #eef1fb; color: #28304f; border-top-left-radius: 6px; }
    .bubble.user { align-self: flex-end; background: linear-gradient(135deg, var(--accent), var(--primary-2)); color: #fff; border-top-right-radius: 6px; }

    .option-grid,
    .action-row { display: grid; gap: 12px; }
    .option-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .action-row { grid-template-columns: repeat(2, minmax(0, max-content)); justify-content: start; }

    .choice-btn {
      width: 100%; text-align: left; border: 1px solid var(--line); background: #fff; color: var(--text);
      padding: 14px 16px; border-radius: 16px; cursor: pointer; font-weight: 700;
      transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease;
    }

    .choice-btn:hover { border-color: var(--primary-2); transform: translateY(-1px); box-shadow: 0 10px 20px rgba(61,102,230,0.1); }
    .choice-btn small { display: block; color: var(--muted); font-weight: 500; margin-top: 4px; }

    .inline-input {
      width: 100%; border: 1px solid var(--line); background: #fff; padding: 14px 16px; border-radius: 14px; margin-top: 10px;
    }

    .label { font-size: .9rem; color: var(--muted); font-weight: 700; margin-top: 6px; }

    .summary {
      background: rgba(238,241,251,0.86); padding: 16px; border-radius: 16px; border: 1px solid var(--line); color: #2b3558;
    }

    .summary strong { color: var(--primary); }

    .result-box {
      margin-top: 14px; padding: 20px; background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(245,248,255,.98));
    }

    .result-box h4 { margin: 0 0 10px; font-size: 1.4rem; color: var(--primary); }
    .result-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
    .note { color: var(--muted); font-size: .95rem; margin-top: 10px; }

    .footer {
      padding: 54px 0 28px; border-top: 1px solid rgba(61,102,230,0.08); background: rgba(255,255,255,0.55);
    }

    .footer-grid { display: grid; grid-template-columns: 1.25fr 1fr 1fr; gap: 28px; margin-bottom: 22px; }
    .footer h4 { margin: 0 0 12px; font-size: 1.2rem; }
    .footer p, .footer li, .footer a { color: var(--muted); }
    .footer ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
    .bottom { border-top: 1px solid rgba(61,102,230,0.08); padding-top: 20px; display: flex; justify-content: space-between; gap: 20px; flex-wrap: wrap; color: var(--muted); }

    @media (max-width: 980px) {
      .hero-grid, .teacher-grid, .steps, .footer-grid, .option-grid { grid-template-columns: 1fr 1fr; }
      .nav-links { display: none; }
    }

    @media (max-width: 720px) {
      .hero-grid, .teacher-grid, .steps, .footer-grid, .option-grid, .action-row { grid-template-columns: 1fr; }
      .hero-media img { min-height: 280px; }
      .hero-actions, .result-actions, .bottom { flex-direction: column; align-items: stretch; }
      .btn { width: 100%; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="container nav">
      <a class="brand" href="index.html">
        <img src="logo.png" alt="S+ English Academy logo" onerror="this.src='S+ Eng Academy.png'" />
